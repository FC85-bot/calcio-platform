PROJECT_NAME=Calcio Platform API
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=calcio
POSTGRES_PASSWORD=calcio
POSTGRES_DB=calcio_platform
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_PRE_PING=true
DATABASE_ECHO=false
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Local bootstrap default: mock provider for end-to-end verification
INGESTION_PROVIDER=mock_provider
RAW_STORAGE_PATH=data/raw
PROVIDER_TIMEOUT_SECONDS=20
PROVIDER_RETRY_ATTEMPTS=3
PROVIDER_RETRY_BACKOFF_SECONDS=1.0

FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_API_KEY=your_token_here
FOOTBALL_DATA_COMPETITION_CODES=["SA"]
# FOOTBALL_DATA_SEASON_YEAR=2025

# Dedicated odds provider used for Sprint 10 odds history layer
THE_ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
THE_ODDS_API_API_KEY=your_the_odds_api_key_here
THE_ODDS_API_SPORT_KEYS=["soccer_italy_serie_a"]
THE_ODDS_API_REGIONS=["eu"]
# Optional explicit bookmaker filter. Leave empty to use regions.
THE_ODDS_API_BOOKMAKERS=[]

# Frontend runtime override for Docker/remote setups
# CALCIO_API_BASE_URL=http://127.0.0.1:8000/api/v1
